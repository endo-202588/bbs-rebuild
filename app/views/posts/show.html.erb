<div class="container mx-auto px-4">

  <div class="max-w-3xl mx-auto mt-10">

    <!-- タイトル + 編集ボタン -->
    <div class="flex justify-between items-start mb-4">

      <h1 class="text-3xl font-bold text-gray-800">
        <%= @post.title %>
      </h1>

      <% if @post.owned_by?(current_user) %>
        <div class="flex gap-2">
          <%= link_to "編集",
              edit_post_path(@post),
              class: "px-3 py-1 text-sm bg-blue-500 text-white rounded hover:bg-blue-600" %>

          <%= link_to "削除",
              post_path(@post),
              data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
              class: "px-3 py-1 text-sm bg-red-500 text-white rounded hover:bg-red-600" %>
        </div>
      <% end %>
    </div>

    <% if @post.image.attached? %>
      <div class="mb-6">
        <%= image_tag @post.image, class: "w-full max-w-md mx-auto h-auto object-cover rounded-lg" %>
      </div>
    <% end %>

    <!-- 本文 -->
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6 min-h-[200px] flex flex-col justify-between">
      <div>
        <p class="text-gray-700 leading-relaxed whitespace-pre-line mb-3"><%= @post.body %></p>
      </div>
      <% if @post.tags.any? %>
        <div class="mt-4">
          <% @post.tags.each do |tag| %>
            <span class="inline-block bg-blue-100 text-blue-700 text-xs px-2 py-1 rounded-full mr-1">
              #<%= tag.name %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="flex justify-between items-center mt-4 text-sm text-gray-500">
      <p>
        投稿者：<span class="font-medium text-gray-700"><%= @post.user.display_name %></span>
      </p>
      <p>
        <%= @post.created_at.strftime("%Y/%m/%d") %>
      </p>
    </div>

    <!-- 戻るリンク -->
    <div class="mt-6">
      <%= link_to "← 投稿一覧に戻る",
          posts_path,
          class: "text-blue-600 hover:underline" %>
    </div>

  </div>

</div>