<div class="container mx-auto px-4">

  <h1 class="text-center mt-6 text-2xl font-bold">投稿一覧</h1>

  <div class="flex justify-end mt-4">
    <%= link_to "新規投稿", new_post_path,
        class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8 items-stretch">

    <% @posts.each do |post| %>
      <div class="relative bg-white p-6 rounded-xl border border-gray-200
                      shadow-sm hover:shadow-xl transition duration-300 cursor-pointer flex flex-col min-h-[220px]">

        <%= link_to "", post_path(post), class: "absolute inset-0" %>

        <h2 class="text-lg font-semibold text-gray-800 mb-2">
          <%= post.title %>
        </h2>

        <div class="flex-1">
          <p class="text-gray-600 text-sm line-clamp-3 whitespace-pre-line mb-3"><%= post.body %></p>
        </div>

        <div>
          <% if post.tags.any? %>
            <div class="mb-2">
              <% post.tags.each do |tag| %>
                <span class="inline-block bg-blue-100 text-blue-700 text-xs px-2 py-1 rounded-full mr-1">
                  #<%= tag.name %>
                </span>
              <% end %>
            </div>
          <% end %>

          <p class="text-xs text-gray-400">
            <%= post.created_at.strftime("%Y/%m/%d") %>
          </p>

          <% if post.owned_by?(current_user) %>
            <div class="flex gap-2 justify-end relative z-10">
              <%= link_to "編集",
                edit_post_path(post),
                class: "px-3 py-1 text-sm bg-blue-500 text-white rounded hover:bg-blue-600" %>

              <%= link_to "削除",
                post_path(post),
                data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
                class: "px-3 py-1 text-sm bg-red-500 text-white rounded hover:bg-red-600" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>