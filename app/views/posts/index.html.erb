<div class="container mx-auto px-4">

  <%= search_form_for @q, url: posts_path, method: :get, class: "mb-6" do |f| %>

    <div class="flex flex-col md:flex-row gap-2 mt-4">

      <!-- キーワード検索 -->
      <%= f.search_field :title_or_body_cont,
          placeholder: "キーワード検索",
          class: "border rounded px-3 py-2 w-full" %>

      <!-- 投稿者 -->
      <%= f.search_field :user_display_name_cont,
          placeholder: "投稿者名",
          class: "border rounded px-3 py-2 w-full" %>

      <!-- タグ -->
      <%= f.search_field :tags_name_cont,
          placeholder: "タグ",
          class: "border rounded px-3 py-2 w-full" %>

    </div>

    <div class="flex gap-2 justify-end mt-4">

      <%= link_to "リセット",
          posts_path,
          class: "px-3 py-2 text-sm bg-gray-200 rounded hover:bg-gray-300 whitespace-nowrap" %>

      <%= f.submit "検索",
          class: "px-4 py-2 text-sm bg-blue-600 text-white rounded hover:bg-blue-700 whitespace-nowrap" %>

    </div>

  <% end %>

  <h1 class="text-center mt-6 text-2xl font-bold">投稿一覧</h1>

  <div class="flex justify-end mt-4">
    <%= link_to "新規投稿", new_post_path,
        class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8 items-stretch">

    <% @posts.each do |post| %>
      <div class="relative bg-white p-6 rounded-xl border border-gray-200
                      shadow-sm hover:shadow-xl transition duration-300 cursor-pointer flex flex-col min-h-[220px]">

        <%= link_to "", post_path(post), class: "absolute inset-0" %>

        <div class="flex gap-4 mb-4">

          <% if post.image.attached? %>
            <div class="w-24 h-24 flex-shrink-0">
              <%= image_tag post.image,
                  class: "w-full h-full object-cover rounded-lg" %>
            </div>
          <% end %>

          <div class="flex-1">

            <h2 class="text-lg font-semibold text-gray-800 mb-1">
              <%= post.title %>
            </h2>

            <p class="text-gray-600 text-sm line-clamp-2 whitespace-pre-line">
              <%= post.body %>
            </p>

          </div>

        </div>

        <div class="mt-auto">
          <% if post.tags.any? %>
            <div class="mb-2">
              <% post.tags.each do |tag| %>
                <span class="inline-block bg-blue-100 text-blue-700 text-xs px-2 py-1 rounded-full mr-1">
                  #<%= tag.name %>
                </span>
              <% end %>
            </div>
          <% end %>

          <div class="flex justify-between items-center mt-4 text-sm text-gray-500 mb-3">
            <p>
              投稿者：<span class="font-medium text-gray-700"><%= post.user.display_name %></span>
            </p>
            <p>
              <%= post.created_at.strftime("%Y/%m/%d") %>
            </p>
          </div>

          <% if post.owned_by?(current_user) %>
            <div class="flex gap-2 justify-end relative z-10">
              <%= link_to "編集",
                edit_post_path(post),
                class: "px-3 py-1 text-sm bg-blue-500 text-white rounded hover:bg-blue-600" %>

              <%= link_to "削除",
                post_path(post),
                data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
                class: "px-3 py-1 text-sm bg-red-500 text-white rounded hover:bg-red-600" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-8 mb-3 flex justify-center">
    <%= paginate @posts %>
  </div>
</div>