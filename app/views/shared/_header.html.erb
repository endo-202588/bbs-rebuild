<header class="bg-gray-100 border-b">
  <div class="container mx-auto px-4 py-3 flex justify-between items-center">

    <div>
      <span class="font-semibold">
        <%= current_user.display_name %>
      </span>
    </div>

    <div class="flex gap-6">
      <% if current_user.admin? %>
        <div class="relative group">
          <button class="text-gray-700 font-medium">管理</button>

          <div class="absolute left-0 hidden group-hover:block bg-white border rounded shadow-md w-40">

            <%= link_to "ダッシュボード",
                admin_root_path,
                class: "block px-4 py-2 hover:bg-gray-100" %>

            <%= link_to "ユーザー管理",
                admin_users_path,
                class: "block px-4 py-2 hover:bg-gray-100" %>

            <%= link_to "投稿管理",
                admin_posts_path,
                class: "block px-4 py-2 hover:bg-gray-100" %>

          </div>
        </div>
      <% end %>

      <div>
        <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete }, class: "text-blue-600 hover:underline" %>
      </div>
    </div>

  </div>
</header>
